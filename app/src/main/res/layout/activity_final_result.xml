<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/jungle_bg">

    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F2141811" />

    <TextView
        android:id="@+id/tvWinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:letterSpacing="0.2"
        android:text="VICTORY"
        android:textColor="#FF6D00"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvVictoriousLarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/naluka"
        android:text="VICTORIOUS"
        android:textColor="#FF6D00"
        android:textSize="64sp"
        android:textStyle="bold"
        android:shadowColor="#4DFF6D00"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="20"
        app:layout_constraintBottom_toTopOf="@+id/statsGuideline"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvWinner" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/statsGuideline"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.5" />

    <LinearLayout
        android:id="@+id/llStats"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        android:orientation="horizontal"
        android:weightSum="2"
        app:layout_constraintTop_toBottomOf="@id/statsGuideline">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:background="#1AFFFFFF"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="TOTAL POINTS"
                android:textColor="#B3FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvTotalPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="42 ★"
                android:textColor="#FFD600"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="100dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:background="#1AFFFFFF"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ANCIENT RELICS"
                android:textColor="#B3FFFFFF"
                android:textSize="10sp"
                android:letterSpacing="0.1"/>

            <TextView
                android:id="@+id/tvRelics"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3 ✨"
                android:textColor="#D1C4E9"
                android:textSize="32sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnPlayAgain"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="48dp"
        android:background="#FF5722"
        android:text="▶  PLAY AGAIN"
        android:textColor="#000000"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/llStats" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/btnBackToLobby"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginHorizontal="48dp"
        android:layout_marginTop="16dp"
        android:background="#2E332D"
        android:text="👥  BACK TO LOBBY"
        android:textColor="#B3FFFFFF"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/btnPlayAgain" />

</androidx.constraintlayout.widget.ConstraintLayout>